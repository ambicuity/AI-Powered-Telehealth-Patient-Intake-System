{
  "name": "telehealth-ai-intake",
  "version": "1.0.0",
  "description": "AI-Powered Telehealth Patient Intake System",
  "private": true,
  "workspaces": [
    "frontend",
    "ml-service"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:ml\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && php artisan serve",
    "dev:ml": "cd ml-service && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8001",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:frontend && npm run test:backend && npm run test:ml",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && php artisan test",
    "test:ml": "cd ml-service && pytest",
    "lint": "npm run lint:frontend",
    "lint:frontend": "cd frontend && npm run lint",
    "setup": "npm install && cd frontend && npm install && cd ../ml-service && pip install -r requirements.txt && cd ../backend && composer install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}