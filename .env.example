# Telehealth AI Intake System - Environment Configuration Template
# Copy this file to .env and update with your actual values

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================
PROJECT_NAME=telehealth-ai-intake
ENVIRONMENT=development
APP_VERSION=1.0.0

# =============================================================================
# LARAVEL BACKEND CONFIGURATION  
# =============================================================================
# Generate a new app key with: php artisan key:generate
LARAVEL_APP_KEY=base64:your-32-character-app-key-here

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=telehealth_db
DB_USERNAME=telehealth_user
DB_PASSWORD=secure_database_password_123

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# AWS Configuration
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=telehealth-uploads
AWS_ENDPOINT=http://localstack:4566
AWS_USE_PATH_STYLE_ENDPOINT=true

# Mail Configuration (for production)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@telehealthai.com
MAIL_FROM_NAME="Telehealth AI"

# =============================================================================
# ML SERVICE CONFIGURATION
# =============================================================================
ML_SERVICE_URL=http://ml-service:8001
ML_MODE=sync
ML_TIMEOUT=30
ML_MAX_FILE_SIZE_MB=10

# OCR Configuration
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGE=eng

# AI/ML Configuration
ENABLE_LLM=false
LLM_MODEL=gpt-3.5-turbo
LLM_API_KEY=your_openai_api_key_here
CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME="Telehealth AI Intake"
VITE_APP_VERSION=1.0.0

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Session Configuration
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# Rate Limiting
THROTTLE_REQUESTS_PER_MINUTE=60
THROTTLE_LOGIN_ATTEMPTS=5

# File Upload Security
MAX_FILE_SIZE=10240
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/jpg

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

# Sentry Configuration (for error tracking)
SENTRY_LARAVEL_DSN=your_sentry_dsn_here
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# DOCKER COMPOSE OVERRIDES
# =============================================================================
# MySQL Configuration
MYSQL_ROOT_PASSWORD=root_password_123
MYSQL_DATABASE=telehealth_db
MYSQL_USER=telehealth_user
MYSQL_PASSWORD=secure_database_password_123

# LocalStack Configuration
LOCALSTACK_SERVICES=s3,ssm
LOCALSTACK_DEBUG=1

# =============================================================================
# PRODUCTION ONLY CONFIGURATION
# =============================================================================
# Only set these in production environments

# SSL/TLS Configuration
FORCE_HTTPS=true
SECURE_COOKIES=true

# Cache Configuration for Production
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Production Database (RDS)
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_PORT=3306

# Production S3
# AWS_BUCKET=prod-telehealth-uploads
# AWS_ENDPOINT=null  # Use default AWS endpoints

# CDN Configuration
# CDN_URL=https://your-cloudfront-distribution.cloudfront.net

# Domain Configuration
# APP_URL=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# =============================================================================
# DEVELOPMENT ONLY CONFIGURATION
# =============================================================================
# Only set these in development environments

APP_DEBUG=true
APP_ENV=local

# Development Debugging
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# =============================================================================
# EXAMPLE PRODUCTION VALUES
# =============================================================================
# Uncomment and modify these for production deployment

# Production App Configuration
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.telehealthai.com
# FRONTEND_URL=https://telehealthai.com

# Production Database
# DB_HOST=telehealth-prod.cluster-xyz.us-east-1.rds.amazonaws.com
# DB_PASSWORD=very_secure_production_password

# Production Cache/Queue
# REDIS_HOST=telehealth-prod.cache.amazonaws.com

# Production S3
# AWS_BUCKET=telehealth-prod-uploads
# AWS_ENDPOINT=null

# Production Security
# SESSION_SECURE_COOKIE=true
# SANCTUM_STATEFUL_DOMAINS=telehealthai.com
# CORS_ALLOWED_ORIGINS=https://telehealthai.com